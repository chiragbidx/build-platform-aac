# Mailvanta SaaS – Required ENV Vars

# Database/Postgres
DATABASE_URL=postgresql://user:pass@host:5432/db
DATABASE_SSL=false

# Auth
AUTH_SECRET=SUPERSECRET
NEXTAUTH_SECRET=SUPERSECRET
BASE_URL=http://localhost:3000

# OpenAI AI Integration (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SendGrid/Bulk email delivery
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=chirag@bidx.ai

# (Optional) Other integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Dashboard
NODE_ENV=development
PORT=3000

# Vercel/Deploy meta (if on Railway etc)
RAILWAY_PUBLIC_DOMAIN=
RAILWAY_PRIVATE_DOMAIN=
RAILWAY_PROJECT_NAME=
RAILWAY_ENVIRONMENT_NAME=
RAILWAY_SERVICE_NAME=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_STATIC_URL=
RAILWAY_ENVIRONMENT=
RAILWAY_SERVICE_SAAS_BOILERPLATE_SOURCE_URL=
RAILWAY_SERVICE_PANDA_STUDIO_QWS_URL=
RAILWAY_SERVICE_BUILD_PLATFORM_AAC_URL=
RAILWAY_SERVICE_CREATOR_SUITE_JEI_URL=
RAILWAY_SERVICE_ORBIT_LABS_BXV_URL=
RAILWAY_SERVICE_WEB_MASON_TJZ_URL=

# Storage (if needed)
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=